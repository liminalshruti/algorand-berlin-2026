    "contract": {
        "name": "ValidationRegistry",
        "methods": [
            {
                "name": "initialize",
                "args": [
                    {
                        "type": "uint64",
                        "name": "identityApp"
                    }
                ],
                "readonly": false,
                "returns": {
                    "type": "void"
                },
                "desc": "Set the Identity registry app id (0 keeps the owner guard on the local registry)."
            },
            {
                "name": "setAgentOwner",
                "args": [
                    {
                        "type": "uint64",
                        "name": "agentId"
                    },
                    {
                        "type": "address",
                        "name": "owner"
                    }
                ],
                "readonly": false,
                "returns": {
                    "type": "void"
                },
                "desc": "DEV/TEST seam (deferred identity): register an agent's owner locally."
            },
            {
                "name": "validationRequest",
                "args": [
                    {
                        "type": "address",
                        "name": "validator"
                    },
                    {
                        "type": "uint64",
                        "name": "agentId"
                    },
                    {
                        "type": "string",
                        "name": "requestURI"
                    },
                    {
                        "type": "byte[32]",
                        "name": "requestHash"
                    }
                ],
                "readonly": false,
                "returns": {
                    "type": "void"
                },
                "desc": "validationRequest (mapping \u00a73.2). Caller MUST be owner/operator of agentId."
            },
            {
                "name": "validationResponse",
                "args": [
                    {
                        "type": "byte[32]",
                        "name": "requestHash"
                    },
                    {
                        "type": "uint8",
                        "name": "response"
                    },
                    {
                        "type": "string",
                        "name": "responseURI"
                    },
                    {
                        "type": "byte[32]",
                        "name": "responseHash"
                    },
                    {
                        "type": "string",
                        "name": "tag"
                    }
                ],
                "readonly": false,
                "returns": {
                    "type": "void"
                },
                "desc": "validationResponse (mapping \u00a73.2). Caller MUST be the named validator; response in 0..100.\nCallable repeatedly for the same request (progressive finality) \u2014 overwrites + bumps lastUpdate."
            },
            {
                "name": "getValidationStatus",
                "args": [
                    {
                        "type": "byte[32]",
                        "name": "requestHash"
                    }
                ],
                "readonly": true,
                "returns": {
                    "type": "(address,uint64,uint8,byte[32],string,uint64)"
                },
                "desc": "getValidationStatus (mapping \u00a73.2)."
            },
            {
                "name": "getSummary",
                "args": [
                    {
                        "type": "uint64",

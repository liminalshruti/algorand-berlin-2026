# Optional local overrides. The demo defaults are committed in `.env.demo`, which
# is loaded before this gitignored `.env` file. Leave blank values out of `.env`;
# blank placeholders are ignored so copied examples do not erase demo defaults.

# ── Algorand network (router-server) ────────────────────────────────────────
# TestNet defaults live in `.env.demo`. Override these only for LocalNet/custom nodes.
ALGO_NETWORK=testnet
ALGOD_URL=https://testnet-api.algonode.cloud
ALGOD_SERVER=https://testnet-api.algonode.cloud
ALGOD_PORT=443
ALGOD_TOKEN=
INDEXER_URL=https://testnet-idx.algonode.cloud
INDEXER_PORT=443
INDEXER_TOKEN=

# ── Deployed ARC-8004 app-ids ────────────────────────────────────────────────
# Public app-ids already live in `.env.demo`, `apps/web/deployed.testnet.json`,
# and `docs/status/DEPLOYED.md`. Override only after a redeploy.
IDENTITY_APP_ID=764031067
REPUTATION_APP_ID=764031363
VALIDATION_APP_ID=764031094

# ── Dev helpers ──────────────────────────────────────────────────────────────
# Allow POST /api/agents/seed to register the whole Liminal roster in one call.
ALLOW_SEED=
PORT=3001

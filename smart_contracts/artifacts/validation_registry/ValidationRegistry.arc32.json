                    },
                    {
                        "type": "address[]",
                        "name": "validators"
                    },
                    {
                        "type": "string",
                        "name": "tag"
                    }
                ],
                "readonly": true,
                "returns": {
                    "type": "(uint64,uint8)"
                },
                "desc": "getSummary (mapping \u00a73.2). Empty validators list = all validators."
            },
            {

{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": "dist",
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false
  },
  "include": [
    "contracts/index.ts",
    "contracts/*/deploy-config.ts",
    "contracts/artifacts/**/*.ts"
  ],
  "exclude": ["node_modules", "dist", "coverage"]
}

# ── Algorand network (router-server) ────────────────────────────────────────
# Defaults to TestNet with a shared throwaway payer when unset (see context.ts).
ALGO_NETWORK=testnet
ALGOD_URL=https://testnet-api.algonode.cloud
ALGOD_PORT=443
ALGOD_TOKEN=
# Funded payer that settles x402 payments + anchors notes. Falls back to the
# public shared TestNet payer in context.ts if unset. NEVER use a MainNet key.
PAYER_MNEMONIC=

# ── Contract deploy (npm run deploy) ─────────────────────────────────────────
# AlgorandClient.fromEnvironment() reads these. DEPLOYER must be funded on TestNet.
DEPLOYER_MNEMONIC=
# algokit-utils also accepts ALGOD_SERVER/ALGOD_PORT/ALGOD_TOKEN for fromEnvironment.
ALGOD_SERVER=https://testnet-api.algonode.cloud

# ── Deployed ARC-8004 app-ids ────────────────────────────────────────────────
# Already deployed on TestNet (source of truth: public/deployed.testnet.json + DEPLOYED.md).
# Public app-ids, safe to commit. Redeploy: `npm run deploy:testnet`.
IDENTITY_APP_ID=764031067
REPUTATION_APP_ID=764031363
VALIDATION_APP_ID=764031094

# ── On-chain write submitters (owner of agents / feedback) ───────────────────
# Falls back to PAYER_MNEMONIC. For the consistent-wallet story use Reza's funded
# wallet so every agent is owned by NDX7OC2…HVUCIQ.
IDENTITY_SUBMITTER_MNEMONIC=
REPUTATION_SUBMITTER_MNEMONIC=

# ── Dev helpers ──────────────────────────────────────────────────────────────
# Allow POST /api/agents/seed to register the whole Liminal roster in one call.
ALLOW_SEED=
PORT=3001

flowchart TB
  subgraph ACTORS["ACTORS (Txn.sender)"]
    AGENT["Agent owner<br/>registers & owns the NFT"]
    CLIENT["Client<br/>gives feedback"]
    VALIDATOR["Validator backend<br/>re-exec / zkML / TEE (off-chain)"]
  end

  subgraph IDENTITY["IdentityRegistry — ARC-72 NFT (ERC-8004 §1)"]
    direction TB
    ID_W["register(agentURI,metadata) -> agentId<br/>mint to sender; agentWallet=sender<br/>setAgentURI / setMetadata / setAgentWallet<br/>arc72_transferFrom / approve / setApprovalForAll"]
    ID_BOX["BoxMap state<br/>owners · uris · agentWallets<br/>approvals · operatorApprovals<br/>balances · metadata · agentAtIndex<br/>Global: nextId, supply"]
    ID_R["readonly: arc72_ownerOf · tokenURI<br/>getAgentURI · getMetadata · getAgentWallet<br/>balanceOf · totalSupply · supportsInterface"]
    ID_W --> ID_BOX --> ID_R
  end

  subgraph REPUTATION["ReputationRegistry (ERC-8004 §2)"]
    direction TB
    REP_W["giveFeedback(agentId,value,dec,tags,uri,hash)<br/>self-feedback prohibited (when owner known)<br/>revokeFeedback · appendResponse"]
    REP_BOX["BoxMap state<br/>lastIndex · feedback rows · clientList<br/>respCount · owners (deferred seam)<br/>Global: identityAppId (0=deferred)"]
    REP_R["readonly: getSummary (Sybil guard, int128 net)<br/>readFeedback · readAllFeedback<br/>getResponseCount · getClients · getLastIndex"]
    REP_W --> REP_BOX --> REP_R
  end

  subgraph VALIDATION["ValidationRegistry (ERC-8004 §3)"]
    direction TB
    VAL_W["validationRequest(validator,agentId,uri,hash)<br/>owner/operator guard (when owner known)<br/>validationResponse(hash,0..100,...) — named validator only<br/>progressive finality: overwrite + lastUpdate bump"]
    VAL_BOX["BoxMap state keyed by requestHash<br/>validation records · agentValidations<br/>validatorRequests · owners (deferred seam)<br/>Global: identityAppId (0=deferred)"]
    VAL_R["readonly: getValidationStatus<br/>getSummary (avg response, tag filter)<br/>getAgentValidations · getValidatorRequests"]
    VAL_W --> VAL_BOX --> VAL_R
  end

  EVENTS["ARC-28 emitted events (not stored)<br/>Registered · URIUpdated · MetadataSet<br/>arc72_Transfer/Approval/ApprovalForAll<br/>NewFeedback · FeedbackRevoked · ResponseAppended<br/>ValidationRequest · ValidationResponse"]
  INDEXER["Off-chain indexers / explorer<br/>lora.algokit.io"]

  ROUTER["Off-chain Router (apps/router/src)<br/>validation.ts verdict + repState<br/>PRODUCTION SEAM: call giveFeedback /<br/>validationResponse via generated clients"]

  AGENT -->|register| ID_W
  CLIENT -->|giveFeedback| REP_W
  AGENT -->|validationRequest| VAL_W
  VALIDATOR -->|validationResponse| VAL_W

  ID_R -. "canonical identity {agentRegistry, agentId}" .-> REP_BOX
  ID_R -. "owner resolution when identityAppId set" .-> VAL_BOX
  REP_BOX -. "resolveOwner (deferred -> Identity app)" .-> ID_R
  VAL_BOX -. "resolveOwner (deferred -> Identity app)" .-> ID_R

  ID_W --> EVENTS
  REP_W --> EVENTS
  VAL_W --> EVENTS
  EVENTS --> INDEXER

  ROUTER -. "TODO: x402 paymentTxid+nonce" .-> REP_W
  ROUTER -. "verdict 0..100" .-> VAL_W
